# Throwaway values for local dev-stack bring-up only.
# Replace with real values before any production use.

ENV=dev

# Django
DJANGO_SECRET_KEY=dev-only-not-secret-replace-me-1234567890abcdef

# Admin (currently unused by the code, but compose references them)
ADMIN_USER=admin
ADMIN_USER_EMAIL=admin@example.com
ADMIN_USER_PASSWORD=changeme

# Database
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=yipee
DATABASE_USER=yogaforyoursake
DATABASE_PASSWORD=devpassword
DATABASE_HOST=postgresql
DATABASE_PORT=5432

# Email — dummy. Worker will fail to actually send, that's expected for Path A.
EMAIL_HOST=smtp.example.com
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=dummy
EMAIL_PORT=587
EMAIL_USE_TLS=True

# AWS — dummy. Django will try to use S3Boto3Storage; reads will fail, that's expected.
AWS_ACCESS_KEY=AKIA_DUMMY
AWS_SECRET_ACCESS_KEY=dummy
AWS_STORAGE_BUCKET_NAME=dummy-bucket

# Mailchimp — dummy
MAILCHIMP_SUBSCRIBERS_ID=dummy
