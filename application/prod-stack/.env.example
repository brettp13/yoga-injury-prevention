# Production environment for the YIP prod-stack.
# Copy this file to ".env" (same directory) and fill in REAL values.
# NEVER commit the real .env (it is gitignored).
#
#   cp .env.example .env && nano .env

# Selects the prod branch of webapp/bin/build.sh (migrations, no S3 collectstatic).
ENV=prod

# --- Django ---
# Generate a long random string, e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=CHANGE_ME

# --- Admin (referenced by compose; create the real superuser with createsuperuser) ---
ADMIN_USER=admin
ADMIN_USER_EMAIL=admin@example.com
ADMIN_USER_PASSWORD=CHANGE_ME

# --- Database (Postgres runs in the postgresql container) ---
# DATABASE_HOST must be the compose service name "postgresql".
# DATABASE_NAME/USER/PASSWORD are also used to initialize the Postgres container.
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=yip
DATABASE_USER=yip
DATABASE_PASSWORD=CHANGE_ME
DATABASE_HOST=postgresql
DATABASE_PORT=5432

# --- Email (SMTP used by Django + the email worker) ---
EMAIL_HOST=smtp.yourprovider.com
EMAIL_HOST_USER=CHANGE_ME
EMAIL_HOST_PASSWORD=CHANGE_ME
EMAIL_PORT=587
EMAIL_USE_TLS=True

# --- AWS S3 ---
# Only needed if you switch static/media back to S3 storage. With the local-static
# setup these can stay blank; the site serves /static directly from the container.
AWS_ACCESS_KEY=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# --- Mailchimp (mailchimp worker) ---
MAILCHIMP_SUBSCRIBERS_ID=
EX_MAILCHIMP_SUBSCRIBERS_ID=
MAILCHIMP_API_KEY=
MAILCHIMP_API_USER=

# --- Stripe ---
TEST_STRIPE_SECRET=
PROD_STRIPE_SECRET=
